# Secrets only — search preferences, budget, districts, and AI settings live in config.toml.

# Telegram
TELEGRAM_BOT_TOKEN=
TELEGRAM_CHAT_ID=

# Gemini (only needed when ai.enabled = true in config.toml)
GEMINI_API_KEY=

# WG-Gesucht credentials (used by auth.py for auto-relogin and scripts/login.py)
WGG_EMAIL=
WGG_PASSWORD=

# Persistent storage path (default: ./data — override on cloud to a mounted volume)
# DATA_DIR=/mnt/data
